# ── Provided automatically by Railway add-ons ────────────────
# (copy these from Railway dashboard → your service → Variables)
DATABASE_URL=postgresql://postgres:password@monorail.proxy.rlwy.net:12345/railway
REDIS_URL=redis://default:password@monorail.proxy.rlwy.net:6379

# ── Generate these yourself (run each command in terminal) ────
# openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_OUTPUT_OF_OPENSSL_RAND_HEX_32
ADMIN_JWT_SECRET=REPLACE_WITH_DIFFERENT_OUTPUT_OF_OPENSSL_RAND_HEX_32
GAME_MASTER_SECRET=REPLACE_WITH_ANOTHER_OUTPUT_OF_OPENSSL_RAND_HEX_32

# ── Set this to your Railway domain after first deploy ────────
CORS_ORIGINS=https://your-app-name.up.railway.app

# ── Leave these exactly as they are ──────────────────────────
NODE_ENV=production
PORT=3000
JWT_EXPIRES_IN=7d
ADMIN_JWT_EXPIRES_IN=8h
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
TZ=Asia/Tashkent
